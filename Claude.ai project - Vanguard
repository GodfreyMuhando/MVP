# MVP
Cotrugli Business School Assignment - Claude.ai project
https://claude.ai/public/artifacts/d9c9f7a8-fe35-483b-8678-aec30893ff62 

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FuelPulse AI — Kenya Fuel Intelligence Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root {
  --teal: #00D4AA;
  --teal-dim: #00A888;
  --teal-glow: rgba(0,212,170,0.15);
  --teal-glow-strong: rgba(0,212,170,0.3);
  --amber: #F5A623;
  --red: #FF4D4D;
  --blue: #4D9FFF;
  --bg-deep: #060C12;
  --bg-mid: #0C1520;
  --bg-card: #101C28;
  --bg-card2: #0E1924;
  --border: rgba(0,212,170,0.15);
  --border-bright: rgba(0,212,170,0.35);
  --text: #E8F4F0;
  --text-dim: #7A9E95;
  --text-muted: #3D6058;
  --font-display: 'Syne', sans-serif;
  --font-body: 'DM Sans', sans-serif;
  --font-mono: 'DM Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg-deep);
  color: var(--text);
  overflow-x: hidden;
  line-height: 1.6;
}

/* GRID NOISE BACKGROUND */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,170,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,170,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(6,12,18,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 14px 0;
}
.nav-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 24px;
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  font-family: var(--font-display);
  font-weight: 800; font-size: 20px;
  color: var(--teal);
  letter-spacing: -0.5px;
}
.nav-logo span { color: var(--text); }
.nav-links { display: flex; gap: 24px; list-style: none; }
.nav-links a {
  font-size: 13px; color: var(--text-dim);
  text-decoration: none; font-family: var(--font-mono);
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--teal); }
.nav-pill {
  background: var(--teal-glow);
  border: 1px solid var(--border-bright);
  color: var(--teal);
  font-size: 12px; font-family: var(--font-mono);
  padding: 5px 14px; border-radius: 20px;
  animation: pulse-border 2s infinite;
}
@keyframes pulse-border {
  0%,100% { box-shadow: 0 0 0 0 var(--teal-glow); }
  50% { box-shadow: 0 0 0 6px transparent; }
}

/* HERO */
.hero {
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: center;
  padding: 120px 0 80px;
  position: relative; overflow: hidden;
}
.hero-glow {
  position: absolute; top: 20%; left: 50%;
  transform: translateX(-50%);
  width: 800px; height: 500px;
  background: radial-gradient(ellipse, rgba(0,212,170,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--teal-glow); border: 1px solid var(--border-bright);
  color: var(--teal); font-family: var(--font-mono); font-size: 12px;
  padding: 6px 16px; border-radius: 20px; margin-bottom: 28px;
}
.hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--teal); border-radius: 50%; animation: blink 1.5s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(52px, 8vw, 96px);
  font-weight: 800;
  line-height: 0.95;
  letter-spacing: -3px;
  margin-bottom: 24px;
}
.hero h1 .fp { color: var(--teal); }
.hero h1 .ai { color: rgba(255,255,255,0.25); font-size: 0.6em; }

.hero-tagline {
  font-size: 20px; color: var(--text-dim);
  max-width: 560px; margin-bottom: 48px;
  font-weight: 300; line-height: 1.5;
}

.hero-stats {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 16px; margin-bottom: 48px;
}
.hstat {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px; padding: 20px;
  position: relative; overflow: hidden;
  transition: border-color 0.3s, transform 0.2s;
  cursor: default;
}
.hstat:hover { border-color: var(--border-bright); transform: translateY(-2px); }
.hstat::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--teal-glow) 0%, transparent 60%);
  opacity: 0; transition: opacity 0.3s;
}
.hstat:hover::after { opacity: 1; }
.hstat-val {
  font-family: var(--font-display); font-size: 32px; font-weight: 700;
  color: var(--text); margin-bottom: 4px;
}
.hstat-val.up { color: var(--red); }
.hstat-val.teal { color: var(--teal); }
.hstat-lbl { font-size: 12px; color: var(--text-dim); font-family: var(--font-mono); }

.hero-scroll {
  display: flex; align-items: center; gap: 10px;
  color: var(--text-muted); font-size: 13px; font-family: var(--font-mono);
  animation: float 3s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }
.hero-scroll svg { animation: float 3s ease-in-out infinite; }

/* SECTION HEADERS */
.section { padding: 80px 0; }
.section-label {
  font-family: var(--font-mono); font-size: 11px;
  color: var(--teal); letter-spacing: 0.15em;
  text-transform: uppercase; margin-bottom: 12px;
  display: flex; align-items: center; gap: 10px;
}
.section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); max-width: 60px; }
.section-title {
  font-family: var(--font-display); font-size: clamp(32px, 5vw, 52px);
  font-weight: 700; letter-spacing: -1.5px; margin-bottom: 12px;
  line-height: 1.05;
}
.section-sub { color: var(--text-dim); font-size: 16px; max-width: 540px; margin-bottom: 48px; }

/* CARDS */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px; padding: 28px;
  transition: border-color 0.3s, transform 0.2s;
  position: relative; overflow: hidden;
}
.card:hover { border-color: var(--border-bright); transform: translateY(-3px); }
.card-glow {
  position: absolute; top: 0; right: 0;
  width: 120px; height: 120px;
  background: radial-gradient(circle, var(--teal-glow) 0%, transparent 70%);
  pointer-events: none;
}

/* PAIN METER */
.pain-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 32px; }
.pain-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px; padding: 28px;
  position: relative; overflow: hidden;
  transition: all 0.3s;
}
.pain-card:hover { transform: translateY(-4px); border-color: var(--border-bright); }
.pain-card.alert { border-color: rgba(255,77,77,0.3); }
.pain-card.alert:hover { border-color: rgba(255,77,77,0.6); }
.pain-num {
  font-family: var(--font-display); font-size: 48px; font-weight: 800;
  line-height: 1; margin-bottom: 8px;
}
.pain-num.red { color: var(--red); }
.pain-num.amber { color: var(--amber); }
.pain-num.teal { color: var(--teal); }
.pain-label { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); }
.pain-sub { font-size: 14px; color: var(--text-dim); margin-top: 8px; line-height: 1.4; }

.alert-banner {
  background: linear-gradient(135deg, rgba(255,77,77,0.1), rgba(255,77,77,0.05));
  border: 1px solid rgba(255,77,77,0.25);
  border-radius: 16px; padding: 20px 24px;
  display: flex; align-items: flex-start; gap: 16px;
  margin-bottom: 32px;
}
.alert-icon { font-size: 24px; flex-shrink: 0; margin-top: 2px; }
.alert-title { font-weight: 500; color: #FF8080; margin-bottom: 4px; font-size: 15px; }
.alert-body { color: var(--text-dim); font-size: 14px; line-height: 1.5; }

/* METER BAR */
.meter-wrap { margin-top: 32px; }
.meter-label-row {
  display: flex; justify-content: space-between;
  font-family: var(--font-mono); font-size: 12px;
  color: var(--text-dim); margin-bottom: 10px;
}
.meter-track {
  height: 10px; background: rgba(255,255,255,0.06);
  border-radius: 10px; overflow: hidden; position: relative;
}
.meter-fill {
  height: 100%; border-radius: 10px;
  background: linear-gradient(90deg, var(--teal), var(--amber), var(--red));
  transition: width 1.5s cubic-bezier(0.4,0,0.2,1);
}
.meter-ticks {
  display: flex; justify-content: space-between;
  margin-top: 6px; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted);
}

/* CHART SECTION */
.chart-tabs { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
.chart-tab {
  padding: 8px 18px; border-radius: 20px; font-size: 13px;
  border: 1px solid var(--border); background: transparent;
  color: var(--text-dim); cursor: pointer;
  font-family: var(--font-mono);
  transition: all 0.2s;
}
.chart-tab.active {
  background: var(--teal-glow);
  border-color: var(--border-bright);
  color: var(--teal);
}
.chart-tab:hover:not(.active) { border-color: var(--border-bright); color: var(--text); }
.chart-wrap {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 20px; padding: 28px;
}
.chart-meta {
  display: flex; gap: 20px; margin-bottom: 20px; flex-wrap: wrap;
}
.chart-meta-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-dim); }
.chart-meta-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* RISK CARDS */
.risk-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.risk-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 20px; padding: 24px; cursor: pointer;
  transition: all 0.3s; position: relative; overflow: hidden;
}
.risk-card.expanded { border-color: var(--border-bright); }
.risk-card:hover { border-color: var(--border-bright); transform: translateY(-2px); }
.risk-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
.risk-name { font-family: var(--font-display); font-size: 18px; font-weight: 600; }
.risk-level {
  font-family: var(--font-mono); font-size: 11px; padding: 4px 12px;
  border-radius: 20px; font-weight: 500;
}
.risk-level.critical { background: rgba(255,77,77,0.15); color: #FF8080; border: 1px solid rgba(255,77,77,0.2); }
.risk-level.high { background: rgba(245,166,35,0.15); color: var(--amber); border: 1px solid rgba(245,166,35,0.2); }
.risk-level.medium { background: rgba(77,159,255,0.15); color: var(--blue); border: 1px solid rgba(77,159,255,0.2); }
.risk-bar-track { height: 6px; background: rgba(255,255,255,0.06); border-radius: 6px; overflow: hidden; margin-bottom: 12px; }
.risk-bar-fill { height: 100%; border-radius: 6px; transition: width 1s; }
.risk-desc { font-size: 13px; color: var(--text-dim); line-height: 1.5; }
.risk-expand { overflow: hidden; max-height: 0; transition: max-height 0.4s; }
.risk-expand.open { max-height: 200px; }
.risk-detail { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); font-size: 13px; color: var(--text-dim); line-height: 1.6; }
.risk-chevron { color: var(--text-muted); transition: transform 0.3s; font-size: 14px; }
.risk-card.expanded .risk-chevron { transform: rotate(180deg); }

/* COMPETITOR TABLE */
.comp-table-wrap {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 20px; overflow: hidden;
}
.comp-table { width: 100%; border-collapse: collapse; }
.comp-table th {
  background: rgba(0,212,170,0.05);
  padding: 16px 20px; text-align: left;
  font-family: var(--font-mono); font-size: 12px; color: var(--text-dim);
  letter-spacing: 0.05em; font-weight: 400;
  border-bottom: 1px solid var(--border);
}
.comp-table td {
  padding: 16px 20px; font-size: 14px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr.fp-row td { background: rgba(0,212,170,0.04); }
.comp-table tr:hover td { background: rgba(0,212,170,0.03); }
.comp-name { font-weight: 500; color: var(--text); }
.comp-name.fp { color: var(--teal); font-family: var(--font-display); font-size: 15px; }
.tick { color: var(--teal); font-size: 16px; }
.cross { color: var(--text-muted); font-size: 16px; }
.fp-badge {
  background: var(--teal-glow); border: 1px solid var(--border-bright);
  color: var(--teal); font-size: 11px; font-family: var(--font-mono);
  padding: 3px 10px; border-radius: 20px; margin-left: 8px;
}
.region-badge {
  font-size: 11px; font-family: var(--font-mono);
  padding: 3px 10px; border-radius: 20px;
}
.region-global { background: rgba(77,159,255,0.1); color: var(--blue); border: 1px solid rgba(77,159,255,0.2); }
.region-us { background: rgba(245,166,35,0.1); color: var(--amber); border: 1px solid rgba(245,166,35,0.2); }
.region-africa { background: var(--teal-glow); color: var(--teal); border: 1px solid var(--border-bright); }

/* GAMIFICATION */
.badges-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
.badge-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 20px; padding: 20px; text-align: center;
  transition: all 0.3s; cursor: pointer;
}
.badge-card:hover { border-color: var(--border-bright); transform: translateY(-3px); }
.badge-card.locked { opacity: 0.4; }
.badge-icon { font-size: 40px; margin-bottom: 10px; }
.badge-name { font-family: var(--font-display); font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.badge-desc { font-size: 11px; color: var(--text-dim); }
.badge-earned { font-size: 10px; color: var(--teal); margin-top: 6px; font-family: var(--font-mono); }

.leaderboard {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 20px; overflow: hidden;
}
.lb-header {
  padding: 20px 24px;
  background: rgba(0,212,170,0.05);
  border-bottom: 1px solid var(--border);
  font-family: var(--font-display); font-size: 16px; font-weight: 600;
  display: flex; align-items: center; justify-content: space-between;
}
.lb-live { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--teal); font-family: var(--font-mono); font-weight: 400; }
.lb-live::before { content: ''; width: 6px; height: 6px; background: var(--teal); border-radius: 50%; animation: blink 1.5s infinite; }
.lb-row {
  display: flex; align-items: center;
  padding: 14px 24px; border-bottom: 1px solid var(--border);
  transition: background 0.2s; cursor: pointer;
}
.lb-row:last-child { border-bottom: none; }
.lb-row:hover { background: rgba(0,212,170,0.03); }
.lb-row.me { background: rgba(0,212,170,0.05); border-left: 2px solid var(--teal); }
.lb-rank {
  font-family: var(--font-mono); font-size: 16px; font-weight: 500;
  width: 36px; color: var(--text-dim);
}
.lb-rank.gold { color: #FFD700; }
.lb-rank.silver { color: #C0C0C0; }
.lb-rank.bronze { color: #CD7F32; }
.lb-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; margin-right: 12px;
  background: var(--bg-mid);
}
.lb-name { flex: 1; font-size: 14px; font-weight: 500; }
.lb-city { font-size: 12px; color: var(--text-dim); font-family: var(--font-mono); }
.lb-savings { font-family: var(--font-display); font-size: 16px; color: var(--teal); font-weight: 600; }
.lb-savings-lbl { font-size: 11px; color: var(--text-dim); text-align: right; font-family: var(--font-mono); }

/* TECH STACK */
.tech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 40px; }
.tech-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 16px; padding: 20px;
  transition: all 0.2s;
}
.tech-card:hover { border-color: var(--border-bright); transform: translateY(-2px); }
.tech-layer { font-size: 11px; color: var(--teal); font-family: var(--font-mono); margin-bottom: 8px; }
.tech-name { font-family: var(--font-display); font-size: 16px; font-weight: 600; margin-bottom: 6px; }
.tech-desc { font-size: 13px; color: var(--text-dim); }
.tech-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
.tech-tag {
  font-size: 11px; font-family: var(--font-mono);
  padding: 3px 10px; border-radius: 20px;
  background: rgba(255,255,255,0.05); color: var(--text-dim);
  border: 1px solid var(--border);
}

/* ROADMAP */
.roadmap { position: relative; }
.roadmap::before {
  content: ''; position: absolute; left: 19px; top: 0; bottom: 0;
  width: 1px; background: var(--border);
}
.rm-item { display: flex; gap: 24px; padding: 20px 0; position: relative; }
.rm-dot {
  width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-mono); font-size: 13px; font-weight: 500;
  position: relative; z-index: 1;
  border: 2px solid var(--border);
  background: var(--bg-deep);
}
.rm-dot.now { border-color: var(--teal); color: var(--teal); background: var(--teal-glow); box-shadow: 0 0 20px var(--teal-glow-strong); }
.rm-dot.done { border-color: var(--text-muted); color: var(--text-muted); }
.rm-dot.future { border-color: var(--border); color: var(--text-muted); }
.rm-content { flex: 1; padding-top: 8px; }
.rm-phase { font-family: var(--font-mono); font-size: 11px; color: var(--teal); margin-bottom: 4px; }
.rm-title { font-family: var(--font-display); font-size: 18px; font-weight: 600; margin-bottom: 6px; }
.rm-desc { font-size: 14px; color: var(--text-dim); line-height: 1.5; margin-bottom: 10px; }
.rm-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.rm-tag {
  font-size: 11px; font-family: var(--font-mono);
  padding: 3px 10px; border-radius: 20px;
  background: rgba(255,255,255,0.04); color: var(--text-dim);
  border: 1px solid var(--border);
}

/* BUSINESS MODEL */
.biz-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
.biz-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 20px; padding: 24px; position: relative;
  transition: all 0.3s; overflow: hidden;
}
.biz-card:hover { border-color: var(--border-bright); transform: translateY(-3px); }
.biz-tier {
  font-family: var(--font-mono); font-size: 11px;
  color: var(--teal); margin-bottom: 8px;
}
.biz-name { font-family: var(--font-display); font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.biz-price { font-size: 28px; font-weight: 700; color: var(--teal); font-family: var(--font-display); }
.biz-price span { font-size: 14px; color: var(--text-dim); font-family: var(--font-body); font-weight: 300; }
.biz-desc { font-size: 13px; color: var(--text-dim); margin-top: 10px; line-height: 1.5; }
.biz-features { margin-top: 16px; }
.biz-feat { font-size: 13px; color: var(--text-dim); padding: 4px 0; display: flex; align-items: center; gap: 8px; }
.biz-feat::before { content: '→'; color: var(--teal); font-size: 12px; flex-shrink: 0; }

/* FOOTER */
footer {
  padding: 60px 0;
  border-top: 1px solid var(--border);
  text-align: center;
}
.footer-logo {
  font-family: var(--font-display); font-size: 32px; font-weight: 800;
  color: var(--teal); margin-bottom: 12px; letter-spacing: -1px;
}
.footer-sub { color: var(--text-dim); font-size: 14px; margin-bottom: 24px; }
.footer-links { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
.footer-link {
  font-family: var(--font-mono); font-size: 12px; color: var(--text-dim);
  text-decoration: none; transition: color 0.2s;
}
.footer-link:hover { color: var(--teal); }

/* SHARE BLOCK */
.share-block {
  background: linear-gradient(135deg, rgba(0,212,170,0.08), rgba(0,212,170,0.03));
  border: 1px solid var(--border-bright);
  border-radius: 24px; padding: 48px 40px; text-align: center;
  margin: 60px 0 0;
}
.share-title { font-family: var(--font-display); font-size: 36px; font-weight: 700; margin-bottom: 12px; }
